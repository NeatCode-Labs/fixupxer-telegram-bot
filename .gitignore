# Python virtual environment
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/

# Database files (incl. SQLite WAL / SHM sidecars and ad-hoc backups)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.bak
*.bak.*

# Environment variables
.env

# Local-only operations runbook (contains host-specific paths and secrets context)
OPERATIONS.md

# IDE files
.idea/
.vscode/
*.code-workspace

# OS generated files
.DS_Store
Thumbs.db

# Addon and FxEmbed directories (including their .git directories)
Addon/
FxEmbed/

# Exclude nested .git directories
*/**/.git/ 